@startuml actualizarRequisitoFuncional

skinparam linetype polyline

state actualizarRequisitoFuncional as "actualizarRequisitoFuncional()" {

    state " " as RecuperandoRequisito
    state " " as EditandoRequisito
    state " " as GuardandoCambios

    [*] -[#green]-> RecuperandoRequisito
    note on link
    Se solicita actualizar un requisito funcional
    end note

    RecuperandoRequisito -[#green]-> EditandoRequisito
    note on link
    <b>Sistema</b> recupera el requisito
    y permite su edicion
    end note

    EditandoRequisito -[#green]-> GuardandoCambios
    note on link
    <b>Sistema</b> valida los cambios
    introducidos
    end note

    GuardandoCambios -[#green]-> [*]
    note on link
    <b>Sistema</b> guarda la nueva version
    del requisito funcional
    end note
}

actualizarRequisitoFuncional -[#green]-> REQUISITO_FUNCIONAL_ABIERTO
note on link
completarActualizacion()
end note

actualizarRequisitoFuncional -[#red]-> REQUISITOS_FUNCIONALES_ABIERTO
note on link
rechazarActualizacion()
end note

@enduml