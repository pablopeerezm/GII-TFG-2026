@startuml extraerRequisitosFuncionales

skinparam linetype polyline

state extraerRequisitosFuncionales as "extraerRequisitosFuncionales()" {

    state " " as ProcesandoDocumentacion
    state " " as IdentificandoRequisitos
    state " " as RegistrandoRequisitos

    [*] -[#green]-> ProcesandoDocumentacion
    note on link
    Se inicia la extraccion de requisitos funcionales
    end note

    ProcesandoDocumentacion -[#green]-> IdentificandoRequisitos
    note on link
    <b>Sistema</b> procesa la documentacion
    e identifica los requisitos funcionales
    end note

    IdentificandoRequisitos -[#green]-> RegistrandoRequisitos
    note on link
    <b>Sistema</b> prepara el registro
    de los requisitos detectados
    end note

    RegistrandoRequisitos -[#green]-> [*]
    note on link
    <b>Sistema</b> guarda los requisitos funcionales
    en el sistema local
    end note
}

extraerRequisitosFuncionales -[#green]-> REQUISITOS_FUNCIONALES_ABIERTO
note on link
completarExtraccion()
end note

extraerRequisitosFuncionales -[#red]-> DOCUMENTACION_ABIERTA
note on link
rechazarExtraccion()
end note

@enduml