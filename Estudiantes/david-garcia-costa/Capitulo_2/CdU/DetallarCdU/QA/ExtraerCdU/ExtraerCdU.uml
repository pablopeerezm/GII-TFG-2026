@startuml extraerCasosUso

skinparam linetype polyline

state extraerCasosUso as "extraerCasosUso()" {

    state " " as ProcesandoDocumentacion
    state " " as IdentificandoCasosUso
    state " " as RegistrandoCasosUso

    [*] -[#green]-> ProcesandoDocumentacion
    note on link
    Se inicia la extraccion de casos de uso
    end note

    ProcesandoDocumentacion -[#green]-> IdentificandoCasosUso
    note on link
    <b>Sistema</b> procesa la documentacion
    e identifica los casos de uso
    end note

    IdentificandoCasosUso -[#green]-> RegistrandoCasosUso
    note on link
    <b>Sistema</b> prepara el registro
    de los casos de uso detectados
    end note

    RegistrandoCasosUso -[#green]-> [*]
    note on link
    <b>Sistema</b> guarda los casos de uso
    en el sistema local
    end note
}

extraerCasosUso -[#green]-> CASOS_USO_ABIERTO
note on link
completarExtraccion()
end note

extraerCasosUso -[#red]-> DOCUMENTACION_ABIERTA
note on link
rechazarExtraccion()
end note

@enduml