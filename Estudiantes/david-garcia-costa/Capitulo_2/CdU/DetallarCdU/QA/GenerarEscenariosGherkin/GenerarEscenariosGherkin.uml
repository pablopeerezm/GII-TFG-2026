@startuml generarEscenariosGherkin

skinparam linetype polyline

state generarEscenariosGherkin as "generarEscenariosGherkin()" {

    state " " as RecuperandoInformacionFuncional
    state " " as GenerandoEscenarios
    state " " as RegistrandoEscenarios

    [*] -[#green]-> RecuperandoInformacionFuncional
    note on link
    Se solicita generar escenarios Gherkin
    end note

    RecuperandoInformacionFuncional -[#green]-> GenerandoEscenarios
    note on link
    <b>Sistema</b> recupera casos de uso
    y requisitos funcionales
    end note

    GenerandoEscenarios -[#green]-> RegistrandoEscenarios
    note on link
    <b>Sistema</b> procesa la informacion
    y genera los escenarios
    end note

    RegistrandoEscenarios -[#green]-> [*]
    note on link
    <b>Sistema</b> registra los escenarios
    Gherkin generados
    end note
}

generarEscenariosGherkin -[#green]-> ESCENARIOS_GHERKIN_ABIERTO
note on link
completarGeneracion()
end note

generarEscenariosGherkin -[#red]-> REQUISITOS_FUNCIONALES_ABIERTO
note on link
rechazarGeneracion()
end note

@enduml