@startuml consultarDocumentacionProyecto

skinparam linetype polyline

state consultarDocumentacionProyecto as "consultarDocumentacionProyecto()" {

    state " " as SolicitandoProyecto
    state " " as RecuperandoDocumentacion
    state " " as MostrandoDocumentacion

    [*] -[#green]-> SolicitandoProyecto
    note on link
    Se solicita consultar documentacion de proyecto
    end note

    SolicitandoProyecto -[#green]-> RecuperandoDocumentacion
    note on link
    <b>Sistema</b> recibe el proyecto y
    recupera la documentacion asociada
    end note

    RecuperandoDocumentacion -[#green]-> MostrandoDocumentacion
    note on link
    <b>Sistema</b> prepara la informacion
    para su visualizacion
    end note

    MostrandoDocumentacion -[#green]-> [*]
    note on link
    <b>Sistema</b> muestra la documentacion
    registrada para el proyecto
    end note
}

consultarDocumentacionProyecto -[#green]-> DOCUMENTACION_ABIERTA
note on link
completarConsulta()
end note

consultarDocumentacionProyecto -[#red]-> DOCUMENTACION_ABIERTA
note on link
rechazarConsulta()
end note

@enduml