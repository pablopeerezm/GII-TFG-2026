@startuml
left to right direction
title Casos de uso - Ingeniero de QA

actor "Ingeniero de QA" as QA

rectangle "Sistema" {
  usecase "Iniciar\nsesion" as CU01
  usecase "Cerrar\nsesion" as CU02

  usecase "Introducir\ndocumentacion funcional" as CU03
  usecase "Asociar documentacion\na proyecto" as CU04
  usecase "Consultar documentacion\nregistrada de un proyecto" as CU05

  usecase "Extraer\ncasos de uso" as CU06
  usecase "Listar\ncasos de uso" as CU07
  usecase "Consultar\ncaso de uso" as CU08
  usecase "Crear\ncaso de uso" as CU09
  usecase "Actualizar\ncaso de uso" as CU10
  usecase "Eliminar\ncaso de uso" as CU11

  usecase "Extraer requisitos\nfuncionales" as CU12
  usecase "Listar requisitos\nfuncionales" as CU13
  usecase "Consultar requisito\nfuncional" as CU14
  usecase "Crear requisito\nfuncional" as CU15
  usecase "Actualizar requisito\nfuncional" as CU16
  usecase "Eliminar requisito\nfuncional" as CU17

  usecase "Generar escenarios\nGherkin" as CU18
  usecase "Listar escenarios\nGherkin" as CU19

  usecase "Crear borrador de\ncaso de prueba" as CU20
  usecase "Listar\nborradores" as CU21
  usecase "Consultar\nborrador" as CU22
  usecase "Anadir feedback\na borrador" as CU23
  usecase "Regenerar\nborrador" as CU24
  usecase "Aceptar\nborrador" as CU25
  usecase "Rechazar\nborrador" as CU26

  usecase "Generar caso de prueba\nderivado de borrador" as CU27
  usecase "Publicar caso de prueba\nen Kiwi TCMS" as CU28
  usecase "Buscar casos de prueba\nen Kiwi TCMS" as CU29
  usecase "Ver caso de prueba\nen Kiwi TCMS" as CU30
}

QA --> CU01
