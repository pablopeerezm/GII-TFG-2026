@startuml

package "Sistema" {

class Documentacion {
  +idDocumentacion: String
  +tipoEntrada: String
  +contenido: Text
  +referencia: String
  +fechaRegistro: Date
}

class CasoDeUso {
  +idUC: String
  +nombre: String
  +descripcion: Text
  +trazabilidadLiteral: Text
  +estado: String
  +version: Integer
}

class RequisitoFuncional {
  +idRF: String
  +descripcion: Text
  +trazabilidadLiteral: Text
  +estado: String
  +version: Integer
}

class EscenarioGherkin {
  +idEscenario: String
  +titulo: String
  +given: Text
  +when: Text
  +then: Text
}

class Borrador {
  +idBorrador: String
  +resumen: String
  +categoria: String
  +gherkinText: Text
  +estado: String
  +versionActual: Integer
  +feedback: List
  +fechaCreacion: Date
  +fechaActualizacion: Date
  +projectName: String
  +sourceDocuments: List
}

class CasoPrueba {
  +idCaso: String
  +summary: String
  +texto: Text
  +categoria: String
  +prioridad: String
  +estado: String
}

Documentacion  o-- CasoDeUso : origina
Documentacion  o--  RequisitoFuncional : origina

CasoDeUso  --  RequisitoFuncional : traza

EscenarioGherkin  -->  CasoDeUso : cubre / traza
EscenarioGherkin --> RequisitoFuncional : cubre / traza

Borrador  o--  EscenarioGherkin : contiene

CasoPrueba  -->  Borrador : deriva de
}

class KiwiTCMS <<externo>>

CasoPrueba  --> KiwiTCMS : registrar

@enduml