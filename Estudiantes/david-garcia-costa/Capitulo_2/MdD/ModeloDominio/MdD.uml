@startuml

rectangle "Contexto organizativo" {
  rectangle Proyecto
}

rectangle "Modelo de Dominio" {
  rectangle Documentacion
  rectangle CasoDeUso
  rectangle RequisitoFuncional
  rectangle EscenarioGherkin
  rectangle Borrador
  rectangle CasoPrueba

  Proyecto o-- Documentacion

  Documentacion o-- CasoDeUso
  Documentacion o-- RequisitoFuncional

  CasoDeUso -- RequisitoFuncional : traza

  EscenarioGherkin --> CasoDeUso : cubre/traza
  EscenarioGherkin --> RequisitoFuncional : cubre / traza

  Borrador o-- EscenarioGherkin : contiene

  CasoPrueba --> Borrador : deriva de
}

rectangle "KiwiTCMS\n[sistema externo participante]" as KiwiTCMS
CasoPrueba --> KiwiTCMS : registrar

@enduml