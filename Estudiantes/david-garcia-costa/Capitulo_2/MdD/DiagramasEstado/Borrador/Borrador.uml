@startuml
title Diagrama de estados - Borrador


state "Borrador" as Borrador {
[*] --> Generado
Generado --> PendienteRevision : crearBorrador()
PendienteRevision --> EnRevision : abrirBorrador()
EnRevision --> ConFeedback : anadirFeedback()
ConFeedback --> Regenerado : regenerarVersion()
Regenerado --> PendienteRevision : nuevaVersionDisponible()
EnRevision --> Aprobado : aceptarBorrador()
EnRevision --> Rechazado : rechazarBorrador()
Rechazado --> Eliminado : eliminarBorrador()
Aprobado --> [*]
Eliminado --> [*]
}
@enduml