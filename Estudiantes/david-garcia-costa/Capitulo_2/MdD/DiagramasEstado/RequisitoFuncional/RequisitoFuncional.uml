@startuml
title Diagrama de estados - RequisitoFuncional


state "RequisitoFuncional" as RequisitoFuncional {
[*] --> Identificado
Identificado --> Revisado : revisar()
Revisado --> Modificado : modificar()
Modificado --> Revisado : completarRevision()
Revisado --> Aprobado : aprobar()
Identificado --> Eliminado : eliminar()
Revisado --> Eliminado : eliminar()
Modificado --> Eliminado : eliminar()
Aprobado --> [*]
Eliminado --> [*]

}

@enduml