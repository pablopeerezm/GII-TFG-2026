@startuml Netkia_Analytics
left to right direction
skinparam shadowing false
skinparam roundcorner 15
skinparam  BackgroundColor #000000
skinparam actor {
  BackgroundColor #4B3FA6
  BorderColor #CCCCCC
  FontColor #FFFFFF
}
skinparam ArrowColor #FFFFFF
skinparam rectangle {
  BorderColor #CCCCCC
  FontColor #FFFFFF
}

actor "Director\nDatos globales sin filtro\n\n28 CU disponibles" as Director #4B3FA6

actor "Responsable\nScope inyectado en JWT:\nemployee_ids\ndepartment_ids\nproject_ids\n\n25 CU disponibles" as Responsable #1F7A63

rectangle "Netkia Analytics\nMódulo externo sobre Odoo v16" as System #3A3A3A {

  rectangle "CU-01 · Autenticarse en el sistema" as CU01 #bb3a29ad

  rectangle "P2 · Panel de control (CU-02, CU-03)" as P2 #927410

  rectangle "P3–P6 · Entidades operativas\nEmpleados · Departamentos · Proyectos · Tareas" as P3 #927410

  rectangle "P7 · Métricas operativas (CU-12 – CU-21, CU-28)\nProductividad · Riesgo · Lead time · WIP · Workload · ..." as P7 #927410

  rectangle "P8 · Análisis visual y asistencia (CU-22, CU-23)" as P8 #927410

  rectangle "P9 · Rentabilidad financiera (CU-24, CU-26, CU-27)\n★ Exclusivo Director · HTTP 403 para Responsable" as P9 #4B3FA6

  rectangle "P10 · Búsqueda global (CU-25)" as P10 #927410

  rectangle "Middleware JWT · verify_scope()\nHTTP 401/403 · scope inyectado en token" as JWT #444444
}

actor "Odoo v16 ERP\nSistema externo\n\nProporciona:\nhr_employee · res_users\nproject_project · hr_department\nproject_task · hr_attendance\naccount_analytic_line\nmail_tracking_value · mail_message" as Odoo #555555

Director --> CU01
Responsable --> CU01

CU01 --> P2
CU01 --> P3
CU01 --> P7
CU01 --> P8
CU01 --> P9
CU01 --> P10
P10 --> Odoo
P2 --> Odoo
P3 --> Odoo
P7 --> Odoo
P8 --> Odoo
P9 --> Odoo

CU01 --> JWT

@enduml