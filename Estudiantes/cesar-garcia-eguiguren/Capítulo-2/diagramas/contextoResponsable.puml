@startuml Contexto_Responsable
skinparam componentStyle rectangle
skinparam component {
  BackgroundColor #E8F5E9
  BorderColor #27AE60
  FontSize 11
}

actor Responsable as R #LightGreen

component "CU-01\nAutenticarse" as CU01 #FFE4B5
component "CU-02\nOverview [scope]" as CU02 #D5E8D4
component "CU-03\nPanel Manager [scope]" as CU03 #D5E8D4
component "CU-04\nListar Empleados [scope]" as CU04 #E0F2F7
component "CU-05\nResumen Empleado [scope]" as CU05 #E0F2F7
component "CU-06\nListar Departamentos [scope]" as CU06 #E0F2F7
component "CU-07\nResumen Departamento [scope]" as CU07 #E0F2F7
component "CU-08\nListar Proyectos [scope]" as CU08 #E0F2F7
component "CU-09\nResumen Proyecto [scope]" as CU09 #E0F2F7
component "CU-10\nListar Tareas [scope]" as CU10 #E0F2F7
component "CU-11\nDetalle Tarea [scope]" as CU11 #E0F2F7

component "CU-12 Productividad\nCU-13 Cumplimiento\nCU-14 WIP (empleado)\nCU-28 Workload (empleado)\nCU-15 Riesgo (proyecto)\nCU-16 Retrabajo\nCU-17 Exactitud\nCU-18 Lead Time\nCU-19 Tiempo Estado\nCU-20 Canceladas\nCU-21 Tiempo Prioridad" as METRICS_KPI #FFF8DC
component "CU-22\nGráficos Analíticos\n(3 charts, sin clientes)" as VISUAL #F0FFF0
component "CU-23\nAsistencia vs Imputaciones\n[solo modo Equipo]" as CU23 #FFF5EE
component "CU-25\nBúsqueda Global [scope]" as CU25 #FFF5EE

R --> CU01 : accede a la app
CU01 --> CU02 : auth OK [scope]

CU02 --> CU03 : Panel Manager
CU02 -> CU04 : Empleados
CU02 -> CU06 : Departamentos
CU02 --> CU08 : Proyectos
CU02 -> CU10 : Tareas
CU02 --> VISUAL : Análisis Visual
CU02 --> CU25 : Búsqueda
CU02 --> METRICS_KPI : Consultar métricas
CU02 --> CU23 : Asistencia
CU03 --> CU05 : click empleado
CU04 --> CU05 : click empleado
CU06 --> CU07 : click departamento
CU07 --> CU05 : click empleado
CU08 --> CU09 : click proyecto
CU05 --> CU10 : tareas del empleado\n[scope]
CU09 --> CU10 : tareas del proyecto\n[scope]
CU10 --> CU11 : click en tarea
CU11 --> CU09 : link proyecto
CU11 --> CU05 : link empleado
CU07 ..> METRICS_KPI : workload de empleados
CU03 .> METRICS_KPI : carga de trabajo
CU05 .> METRICS_KPI : WIP, workload, productividad [scope]
CU09 .> METRICS_KPI : eficiencia, riesgo [scope]

CU25 --> CU05 : resultado empleado
CU25 --> CU09 : resultado proyecto
CU25 --> CU11 : resultado tarea

@enduml