@startuml CU25_BusquedaGlobal
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-25 · Realizar Búsqueda Global

start

:CU-01 (JWT válido);
:Actor navega a **/buscar**
(o atajo en la barra lateral);

:Actor escribe en el campo de búsqueda;

if (¿Menos de 2 caracteres?) then (SÍ)
  :EmptyState "Escribe al menos 2 caracteres";
  stop
endif

:Debounce 350ms;

:GET /search/?q=texto&entity=all
 [?entity = tasks|projects|employees];

if (¿Responsable?) then (SÍ)
  :Filtra por project_ids, employee_ids del JWT
   (lógica en backend);
endif

:Resultados agrupados (máx 10 por tipo):
 · Tareas (por nombre o código)
 · Proyectos (por nombre JSONB o código)
 · Empleados (por nombre);

if (¿Total == 0?) then (SÍ)
  :EmptyState "Sin resultados para ...";
  stop
endif

:Actor puede filtrar por tipo de entidad
 [Todos][Tareas][Proyectos][Empleados];

if (¿Click en resultado?) then (Tarea)
  :Navega a CU-11 /tareas/{id};
else if (¿Click en resultado?) then (Proyecto)
  :Navega a CU-09 /proyectos/{id};
else (Empleado)
  :Navega a CU-05 /empleados/{id};
endif

stop

@enduml
