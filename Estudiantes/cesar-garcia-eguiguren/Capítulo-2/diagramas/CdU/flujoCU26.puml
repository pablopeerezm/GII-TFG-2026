@startuml CU26_LineasProyecto
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-26 · Consultar Líneas Analíticas de Proyecto

start

:CU-01 (JWT válido, role = director);

:Actor en CU-24 hace click en
 "Ver Detalles" de un proyecto;

:GET /metrics/profitability/per-project/{id}/lines
 [?date_from & date_to & manager_id];

:Devuelve account_analytic_line del proyecto
 separadas en:
 · incomes: amount >= 0
 · expenses: amount < 0;

:Panel con dos tablas:
 **Ingresos (N)**: fecha | nombre | importe | horas
 **Gastos (N)**: fecha | nombre | importe | horas;

if (¿Sin líneas?) then (SÍ)
  :Tablas vacías;
endif

stop

@enduml
