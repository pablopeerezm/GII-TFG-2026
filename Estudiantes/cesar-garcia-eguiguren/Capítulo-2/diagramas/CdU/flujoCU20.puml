@startuml CU20_TareasCanceladas
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-20 · Consultar Tareas Canceladas

start

:CU-01 (JWT válido);
:Actor en **/métricas**;

:GET /metrics/cancelled-tasks
 [?project_id & date_from & date_to & root_only];

:CancelledTasksService.calculate()
 total: todas las tareas en scope
 canceladas: tareas cuya etapa.name == "Cancelado"
  (comparación case-insensitive);

:cancelled_pct = (canceladas / total) × 100;

:KPIs:
· Porcentaje canceladas
· Número de canceladas
· Total tareas;

:Semáforo referencial:
< 5% verde · 5-10% naranja · > 10% rojo;

stop

@enduml
