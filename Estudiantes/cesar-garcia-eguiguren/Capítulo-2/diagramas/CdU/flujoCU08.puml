@startuml CU08_ListarProyectos
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-08 · Listar Proyectos

start

:CU-01 (JWT válido);
:Actor navega a **/proyectos**;

:GET /projects/;

if (¿Responsable?) then (SÍ)
  :Filtra: Project.id IN (project_ids del JWT);
else (Director)
  :Sin filtro adicional;
endif

if (¿Sin proyectos?) then (SÍ)
  :EmptyState "Sin proyectos";
  stop
endif

:Cuadrícula de tarjetas:
· Nombre del proyecto
· Nombre del cliente (partner_name)
· Código (code)
· Badge ID;

if (¿Click en tarjeta?) then (SÍ)
  :Navega a CU-09 /proyectos/{id};
endif

stop

@enduml
