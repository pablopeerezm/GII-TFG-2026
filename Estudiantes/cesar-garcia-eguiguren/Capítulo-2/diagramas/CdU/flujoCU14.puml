@startuml CU14_WIP
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-14 · Consultar WIP de Empleado

start

:CU-01 (JWT válido);
:Actor en /métricas selecciona empleado
 en panel de parámetros;

:verify_employee_scope(cu, employee_id);

if (¿Fuera de scope?) then (SÍ)
  :HTTP 403;
  stop
endif

:Actor hace click en tarjeta "WIP";

:GET /metrics/wip?employee_id=X [&root_only]
 → WIPService.calculate();

:get_user_id_for_employee(db, employee_id);

if (¿Sin user_id vinculado?) then (SÍ)
  :WIPResponse(wip_count=0, status="optimo",
   recommendation="Sin tareas asignadas");
  stop
endif

:COUNT tareas abiertas asignadas al user_id
 (JOIN TaskAssignment + open_stage_ids_subq)
 [con root_only si aplicable];

if (wip_count ≤ 3) then
  :Status: **ÓPTIMO** (verde)
   Rec: "Carga óptima de trabajo";
else if (wip_count ≤ 5) then
  :Status: **ACEPTABLE** (amarillo)
   Rec: "Considera priorizar tareas";
else
  :Status: **SOBRECARGADO** (rojo)
   Rec: "Cierra tareas antes de comenzar nuevas";
endif

:KPI numérico de wip_count;
:Badge de estado;
:Texto de recomendación;

stop

@enduml