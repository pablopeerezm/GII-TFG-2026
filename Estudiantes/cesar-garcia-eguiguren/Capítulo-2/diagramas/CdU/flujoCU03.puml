@startuml CU03_Manager
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteFontColor #07090F
title CU-03 · Consultar Panel Manager

start

:CU-01 (JWT válido);
:Actor navega a **/manager**;

:Actor puede filtrar por **departamento** (select);

:GET /dashboards/summary/manager [?department_id];

note right
  Parámetros posibles:
  department_id, page, page_size,
  sort_by, sort_order, status
end note

if (¿Responsable?) then (SÍ)
  :Filtra automáticamente por
   employee_ids y department_ids del JWT;
else (Director)
  :Datos globales;
endif

:Extrae team_summary:
· total_employees
· overloaded_count
· underloaded_count
· without_tasks_count;

:Renderiza **5 botones de estado clicables**
 con contador por categoría:
 Total · Sobrecargado · Normal · Subcargado · Sin tareas;

:Card "Empleados más cargados":
 top_overloaded (top 5 por workload%)
 → enlace a CU-05 por empleado;

:Card "Distribución por estados":
 BarChart horizontal (Recharts) con
 estados vs count — barras clicables;

if (¿Actor hace clic en botón/barra de estado?) then (SÍ)
  :Determina estado seleccionado
   (all | sobrecargado | normal | subcargado | without_tasks);

  :GET /dashboards/summary/manager
   ?status=<estado>&page=<n>
   &page_size=12&sort_by=<col>&sort_order=<dir>;

  :Despliega **tabla de carga paginada**
   (12 por página, ordenable):
   Empleado | Departamento | Tareas pend.
   H. pend. | Barra carga% | Badge estado;

  :Paginación server-side ← /team_workload_pages;

  if (¿Click en fila de empleado?) then (SÍ)
    :Navega a CU-05 /empleados/{employee_id};
  endif

  :Botón "Ocultar lista" → colapsa la tabla;
endif

stop

note right
  ⚠ No existe radar ni pestañas Ejecutivo/Equipo.
  La UI usa botones de estado + BarChart
  + tabla condicional.
end note

@enduml