@startuml CU12_Productividad
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-12 · Consultar Productividad

start

:CU-01 (JWT válido);
:Actor accede a **/métricas**;

:Al cargar /métricas, las métricas "simples"
 (compliance, lead-time, rework-rate)
 se pre-cargan en bulk automáticamente;

:Las métricas que requieren parámetros
 muestran "Selecciona empleado/proyecto";

:Actor puede agrupar por categoría:
 [Todas] [Por proyecto] [Por empleado] [Generales];

if (¿Productividad requiere parámetros?) then (SÍ — con filtros de empleado/proyecto/fechas)
  :Actor selecciona empleado y/o proyecto y/o fechas
   en el panel de parámetros;
endif

:Actor hace click en tarjeta "Productividad";

:GET /metrics/productivity
 [?employee_id & project_id
  & date_from & date_to & root_only];

if (¿Empleado fuera de scope?) then (SÍ)
  :HTTP 403;
  stop
endif

if (¿Proyecto fuera de scope?) then (SÍ)
  :HTTP 403;
  stop
endif


:ProductivityService.calculate();
:get_completed_tasks_with_hours();


:Fórmula por tarea: (planned_hours / actual_hours) × 100
 Solo tareas cerradas con planned_hours > 0 y actual_hours > 0;


stop

@enduml