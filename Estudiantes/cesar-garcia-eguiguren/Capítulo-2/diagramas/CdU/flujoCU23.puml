@startuml CU23_Asistencia
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8

title CU-23 · Consultar Asistencia vs Imputaciones

start

:CU-01 (JWT válido);
:Actor navega a **/asistencia**;

:Rango por defecto: mes actual;

:Actor configura filtros:
 · Rango de fechas (shortcuts: Este mes / 30d / 3m)
 · Modo: [Equipo global] | [Por responsable] (solo Director);

if (Modo == Equipo global) then (SÍ)
  :GET /employees/attendance/comparison
   ?date_from&date_to [&department_id];
else (Por responsable)
  :Actor selecciona manager del select
   (GET /employees/managers/list);
  if (¿Manager seleccionado?) then (NO)
    :Mensaje "Selecciona un responsable";
    stop
  endif
  :GET /employees/attendance/manager/{id}
   ?date_from&date_to;
endif

:Calcular por empleado:
 attendance_hours (hr_attendance)
 timesheet_hours (account_analytic_line)
 diff = timesheet - attendance
 coverage_pct = (timesheet / attendance) × 100;

:4 KPIs (si hay datos):
· Horas fichadas · Horas imputadas
· Diferencia total · Empleados con alerta;

:Gráfico de barras agrupadas: fichadas vs imputadas
 (top 15 empleados por horas fichadas);

:Tabla: Empleado | Depto | Fichadas | Imputadas
 | Diferencia | Cobertura% | Badge;

:Badge cobertura:
 ≥ 95% OK (verde) · ≥ 80% Revisar · < 80% Alerta (rojo);

if (¿Click en empleado de la tabla?) then (SÍ)
  :GET /employees/attendance/{id}/daily
   ?date_from&date_to
   → Gráfico de barras y línea de diferencia
   en panel expandido al pie de la página;
endif

stop

@enduml
